:BOOST

cls

echo.
echo ==========================================================
echo                     BOOST MODE
echo ==========================================================
echo.

echo Preparing optimization...

timeout /t 1 >nul


echo.
echo [1/4] Cleaning temporary files

del /f /s /q "%temp%\*" >nul 2>&1


