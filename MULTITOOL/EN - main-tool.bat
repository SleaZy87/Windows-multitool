if "%choix%"=="1" (

cls

echo Cleaning temporary files...

del /f /s /q "%temp%\*" >nul 2>&1

echo.
echo Cleaning completed !

pause

goto CLEAN

)



if "%choix%"=="2" (

cls

echo Full cleaning...

echo Removing user TEMP files...

del /f /s /q "%temp%\*" >nul 2>&1


echo Removing Windows TEMP files...

del /f /s /q "C:\Windows\Temp\*" >nul 2>&1


echo Cleaning recycle bin...

powershell -command "Clear-RecycleBin -Force" >nul 2>&1


echo Cleaning completed !

pause

goto CLEAN

)



if "%choix%"=="3" (

powershell -command "Clear-RecycleBin -Force"

echo.
echo Recycle Bin emptied !

pause

goto CLEAN

)



if "%choix%"=="4" (

ipconfig /flushdns

echo.
echo DNS cleaned !

pause

goto CLEAN

)



goto CLEAN





:: ==========================
:: MONITORING
:: ==========================


:MONITORING

cls

echo.
echo ==========================================
echo              PC MONITORING
echo ==========================================
echo.

echo CPU :
powershell -NoProfile -Command "Get-CimInstance Win32_Processor | Select Name,LoadPercentage"

echo.

echo RAM :
powershell -NoProfile -Command "$r=Get-CimInstance Win32_OperatingSystem; Write-Host ('RAM Used : ' + [math]::Round(($r.TotalVisibleMemorySize-$r.FreePhysicalMemory)/1MB,2) + ' GB'); Write-Host ('Total RAM : ' + [math]::Round($r.TotalVisibleMemorySize/1MB,2) + ' GB')"


echo.

echo GPU :
powershell -NoProfile -Command "Get-CimInstance Win32_VideoController | Select Name"


echo.

echo DRIVES :
powershell -NoProfile -Command "Get-PSDrive -PSProvider FileSystem | Select Name,Used,Free"


echo.

echo UPTIME :
net stats workstation | find "since"


echo.
echo ==========================================

echo [R] Back
echo [1] Refresh

set /p choix=Choice :


if /i "%choix%"=="R" goto MENU

if "%choix%"=="1" goto MONITORING


goto MONITORING


