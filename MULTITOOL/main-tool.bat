:: ==========================
:: NETTOYAGE
:: ==========================


:CLEAN

cls

echo.
echo ==========================================
echo              NETTOYAGE PC
echo ==========================================
echo.

echo [1] Nettoyage rapide
echo [2] Nettoyage complet
echo [3] Vider corbeille
echo [4] Nettoyer DNS

echo.
echo [R] Retour
echo.


set /p choix=Choix :



if /i "%choix%"=="R" goto MENU



if "%choix%"=="1" (

cls

echo Nettoyage fichiers temporaires...

del /f /s /q "%temp%\*" >nul 2>&1

echo.
echo Nettoyage termine !

pause

goto CLEAN

)



if "%choix%"=="2" (

cls

echo Nettoyage complet...

echo Suppression TEMP utilisateur...

del /f /s /q "%temp%\*" >nul 2>&1


echo Suppression TEMP Windows...

del /f /s /q "C:\Windows\Temp\*" >nul 2>&1


echo Nettoyage corbeille...

powershell -command "Clear-RecycleBin -Force" >nul 2>&1


echo Nettoyage termine !

pause

goto CLEAN

)



if "%choix%"=="3" (

powershell -command "Clear-RecycleBin -Force"

echo.
echo Corbeille vide !

pause

goto CLEAN

)



if "%choix%"=="4" (

ipconfig /flushdns

echo.
echo DNS nettoye !

pause

goto CLEAN

)



goto CLEAN

:: ==========================
:: MONITORING
:: ==========================


:MONITORING

cls

echo.
echo ==========================================
echo              MONITORING PC
echo ==========================================
echo.

echo CPU :
powershell -NoProfile -Command "Get-CimInstance Win32_Processor | Select Name,LoadPercentage"

echo.

echo RAM :
powershell -NoProfile -Command "$r=Get-CimInstance Win32_OperatingSystem; Write-Host ('RAM utilisee : ' + [math]::Round(($r.TotalVisibleMemorySize-$r.FreePhysicalMemory)/1MB,2) + ' GB'); Write-Host ('RAM totale : ' + [math]::Round($r.TotalVisibleMemorySize/1MB,2) + ' GB')"


echo.

echo GPU :
powershell -NoProfile -Command "Get-CimInstance Win32_VideoController | Select Name"


echo.

echo DISQUES :
powershell -NoProfile -Command "Get-PSDrive -PSProvider FileSystem | Select Name,Used,Free"


echo.

echo UPTIME :
net stats workstation | find "depuis"


echo.
echo ==========================================

echo [R] Retour
echo [1] Actualiser

set /p choix=Choix :


if /i "%choix%"=="R" goto MENU

if "%choix%"=="1" goto MONITORING


goto MONITORING





